# Base URL of the FlexReport FastAPI backend the MCP server proxies to.
# Production: https://flexreportfinapi.com
# Local dev:  http://localhost:8080  (the backend's `uvicorn src.main:app --port 8080`)
API_BASE_URL=https://flexreportfinapi.com

# Outbound HTTP timeout (seconds) for calls to the backend.
API_HTTP_TIMEOUT=60

# Host/port this MCP server (streamable-http) binds to.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# JWT for testing. NOT used by the server/container itself — the MCP client
# (e.g. Claude Code via .mcp.json) forwards it as the Authorization header.
# Export it in the shell where you launch the client:  export FLEXREPORT_JWT=...
# Obtain one from the backend's POST /token (OAuth2 password flow).
FLEXREPORT_JWT=
